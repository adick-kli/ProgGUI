# .env.example
# Kopiere diese Datei zu .env und f³lle deine Werte ein

# Debug-Mode
DEBUG=False

# Tool-Pfade (optional, sonst aus settings.json)
ATPROGRAM_PATH=C:\Program Files (x86)\Atmel\Studio\7.0\atbackend\atprogram.exe
ATBACKEND_PATH=C:\Program Files (x86)\Atmel\Studio\7.0\atbackend\atbackend.exe
OBJCOPY_PATH=C:\Program Files (x86)\Atmel\Studio\7.0\toolchain\avr32\avr32-gnu-toolchain\bin\avr32-objcopy.exe

# Logging
LOG_LEVEL=INFO
LOG_FILE=proggui.log